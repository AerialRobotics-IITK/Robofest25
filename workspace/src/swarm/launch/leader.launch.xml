<launch>
    <!-- Zenoh router (global scope) -->
    <node
        pkg="rmw_zenoh_cpp"
        exec="rmw_zenohd"
        name="zenoh_router"
        output="screen"
    />
    <!-- MAVROS under namespace uav1 -->
    <include file="$(find-pkg-share mavros)/launch/apm.launch">
        <arg name="namespace" value="uav1"/>
    </include>

</launch>
